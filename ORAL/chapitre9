        if row == 0:
            # Normalisation symétrique pour Ez
            vmax = np.abs(champ).max() * 0.95 or 1.0
            norm = TwoSlopeNorm(vmin=-vmax, vcenter=0.0, vmax=vmax)
            im = ax.pcolormesh(X, Y, champ, cmap=cmap_ez,
                               norm=norm, shading='auto', rasterized=True)
        else:
            vmax = champ.max() * 0.95 or 1.0
            im = ax.pcolormesh(X, Y, champ, cmap=cmap_amp,
                               vmin=0, vmax=vmax,
