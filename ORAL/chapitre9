print(f"  b   = {b*1e3:.1f} mm   f_c1 = {fc1/1e9:.3f} GHz  f_c2 = {fc2/1e9:.3f} GHz")
print()
for nom, data in resultats.items():
    f_sim = data["f"]
    alpha_ev = np.sqrt(max(0, (np.pi / b)**2 - (2*np.pi*f_sim/c)**2))
    print(f"  Guide {nom:8s}  f = {f_sim/1e9:.3f} GHz  "
          f"f/f_c1 = {f_sim/fc1:.3f}", end="")
    if f_sim < fc1:
        print(f"  →  α = {alpha_ev:.2f} m⁻¹  "
              f"(décroissance sur {1/alpha_ev*1e3:.1f} mm)")
    else:
        beta_g = np.sqrt((2*np.pi*f_sim/c)**2 - (np.pi/b)**2)
        lam_g  = 2*np.pi / beta_g
        vg     = c * np.sqrt(1 - (fc1/f_sim)**2)
        print(f"  →  λ_g = {lam_g*1e3:.1f} mm  v_g = {vg/c:.3f}·c")
