# 4.  SIMULATIONS : GUIDE BLOQUÉ et GUIDE PASSANT
# ═══════════════════════════════════════════════════════════════════════════════

# Les deux cas correspondent à f₀ < f_c1 (bloqué) et f_c1 < f₀ < f_c2 (passant)
# On change la fréquence source tout en gardant la même grille.
f_bloque  = 0.60 * fc1   # en-dessous de la coupure → TE₁ évanescent
f_passant = 0.65 * fc2   # entre f_c1 et f_c2       → TE₁ seul se propage

cas = {
    "bloqué":  f_bloque,
    "passant": f_passant,
}

resultats = {}
for nom, freq in cas.items():
    print(f"\n→ Simulation : guide {nom}  (f = {freq/1e9:.3f} GHz, "
          f"f/f_c1 = {freq/fc1:.3f})")
    Ez_fin, Ez_amp, _ = fdtd_guide(freq, Q=Q_total)
    resultats[nom] = {"Ez": Ez_fin, "amp": Ez_amp, "f": freq}
    print(f"   terminée.  |Ez|_max = {np.abs(Ez_fin).max():.3f} V/m")


