# 8.  ANIMATION
# ═══════════════════════════════════════════════════════════════════════════════
from matplotlib.animation import FuncAnimation

_snap_start = 1200
_snap_every = 12   # 1 frame tous les 12 pas → ~67 frames au total

print("\n→ Calcul des frames pour l'animation…")
frames_b = fdtd_anim_frames(f_bloque,  snap_start=_snap_start, snap_every=_snap_every)
frames_p = fdtd_anim_frames(f_passant, snap_start=_snap_start, snap_every=_snap_every)
n_frames = min(len(frames_b), len(frames_p))
print(f"   {n_frames} frames par cas.")

vmax_b = max(np.abs(f).max() for f in frames_b) * 0.95 or 1.0
vmax_p = max(np.abs(f).max() for f in frames_p) * 0.95 or 1.0

fig_a, axes_a = plt.subplots(1, 2, figsize=(12, 3.0))
fig_a.patch.set_facecolor('#0d1117')
for ax in axes_a:
    ax.set_facecolor('#08090f')

norm_b = TwoSlopeNorm(vmin=-vmax_b, vcenter=0, vmax=vmax_b)
norm_p = TwoSlopeNorm(vmin=-vmax_p, vcenter=0, vmax=vmax_p)

im_b = axes_a[0].pcolormesh(X, Y, frames_b[0], cmap=cmap_ez, norm=norm_b,
                              shading='auto', rasterized=True)
im_p = axes_a[1].pcolormesh(X, Y, frames_p[0], cmap=cmap_ez, norm=norm_p,
                              shading='auto', rasterized=True)

for ax, nom, freq, im in zip(
        axes_a, ["BLOQUÉ", "PASSANT"], [f_bloque, f_passant], [im_b, im_p]):
    for yp in [y_mm[0], y_mm[-1]]:
        ax.axhline(yp, color='#c0c8d0', linewidth=2.0)
    ax.axvline(x_mm[src_i], color='#ffff50', linewidth=0.8,
               linestyle='--', alpha=0.6)
    ax.set_xlabel("x  [mm]", fontsize=8, color='#8b9bb4')
    ax.set_ylabel("y  [mm]", fontsize=8, color='#8b9bb4')
    ax.tick_params(colors='#8b9bb4', labelsize=7)
    for spine in ax.spines.values():
        spine.set_edgecolor('#2a3040')
    ax.set_title(
        f"Guide {nom}  —  f = {freq/1e9:.3f} GHz  (f/f_c1 = {freq/fc1:.2f})",
        fontsize=8, color='#c9d1d9')
    cb = fig_a.colorbar(im, ax=ax, pad=0.02, fraction=0.04)
    cb.ax.tick_params(labelsize=7, colors='#8b9bb4')
    cb.set_label("E_z  [V/m]", fontsize=7, color='#8b9bb4')

time_text = fig_a.text(0.5, 0.99, '', ha='center',
                        color='#cba6f7', fontsize=9, transform=fig_a.transFigure)
fig_a.suptitle("Animation FDTD 2D — champ E_z(x, y, t)",
               fontsize=10, color='#cba6f7', y=1.06)
fig_a.tight_layout()

def update(frame):
    im_b.set_array(frames_b[frame])
    im_p.set_array(frames_p[frame])
    t_ps = (_snap_start + frame * _snap_every) * dt * 1e12
    time_text.set_text(f"t = {t_ps:.0f} ps")
    return im_b, im_p, time_text

anim = FuncAnimation(fig_a, update, frames=n_frames, interval=60, blit=True)
plt.show()