x_mm = np.arange(Nx) * dx * 1e3          # [mm]
y_mm = np.arange(Ny) * dy * 1e3          # [mm]
X, Y = np.meshgrid(x_mm, y_mm, indexing='ij')

fig = plt.figure(figsize=(14, 10))
fig.patch.set_facecolor('#0d1117')

gs = gridspec.GridSpec(
