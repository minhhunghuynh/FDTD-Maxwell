# ═══════════════════════════════════════════════════════════════════════════════
# 3.  NOYAU FDTD
# ═══════════════════════════════════════════════════════════════════════════════

def fdtd_guide(f_source, Q=Q_total, record_snapshots=False):
    """
    Effectue Q itérations de l'algorithme de Yee 2D dans le guide.

    Variables : Ez, B̃x = c·Bx, B̃y = c·By   (notation du projet éq. 15)

    Paramètres
    ----------
    f_source         : float — fréquence de la source [Hz]
    Q                : int   — nombre d'itérations
    record_snapshots : bool  — si True, enregistre des instantanés Ez

    Retours
    -------
    Ez_final  : ndarray(Nx, Ny) — Ez à l'instant final
    Ez_amp    : ndarray(Nx, Ny) — amplitude RMS de Ez
    snapshots : list            — instantanés (si record_snapshots=True)
    """

    # ── Conditions initiales nulles ───────────────────────────────────────────
    Ez   = np.zeros((Nx, Ny))    # Ez[i,   j]        grille entière
    Bx_t = np.zeros((Nx, Ny))    # B̃x[i, j+1/2]   → stocké à l'indice j
    By_t = np.zeros((Nx, Ny))    # B̃y[i+1/2, j]   → stocké à l'indice i

    # ── Amplitude RMS (moyenne exponentielle pondérée de Ez²) ────────────────
    Ez_amp = np.zeros((Nx, Ny))
    alpha_rms = 0.994            # coefficient de lissage

    # ── Profil transverse de la source : sin(πy/b) ───────────────────────────
    # Nul sur les parois (j=0 et j=Ny-1), maximum en j = Ny/2
    j_inner = np.arange(1, Ny - 1)                     # indices intérieurs
    src_profile = np.sin(np.pi * j_inner / (Ny - 1))   # sin(πy/b)

    omega = 2 * np.pi * f_source
    snapshots = []

    # ── Boucle temporelle ─────────────────────────────────────────────────────
    for q in range(Q):
        t = q * dt   # temps courant [s]

        # ── Sous-itération 1 : mise à jour de B̃x et B̃y  (à l'instant q+1/2)
        # éq. (16) généralisée 2D  →  B̃x[i, j+1/2]
        #   B̃x^{q+1/2} = B̃x^{q-1/2}  -  1/2 · (Ez[i,j+1] − Ez[i,j])
        Bx_t[:, :-1] -= 0.5 * (Ez[:, 1:] - Ez[:, :-1])

        # éq. (16) généralisée 2D  →  B̃y[i+1/2, j]
        #   B̃y^{q+1/2} = B̃y^{q-1/2}  +  1/2 · (Ez[i+1,j] − Ez[i,j])
        By_t[:-1, :] += 0.5 * (Ez[1:, :] - Ez[:-1, :])

        # ── Sous-itération 2 : mise à jour de Ez  (à l'instant q+1)
        # éq. (16) généralisée 2D  (partie intérieure, hors parois et bords)
        #   Ez^{q+1} = Ez^q
        #            + 1/2 · (B̃y[i,j]   − B̃y[i-1,j])
        #            − 1/2 · (B̃x[i,j]   − B̃x[i,j-1])
        #            − (Δt/ε₀) · Jz^{q+1/2}
        Ez[1:-1, 1:-1] += (
              0.5 * (By_t[1:-1, 1:-1] - By_t[:-2,  1:-1])
            - 0.5 * (Bx_t[1:-1, 1:-1] - Bx_t[1:-1, :-2])
        )

        # ── Injection de source — densité de courant sinusoïdale  Jz ─────────
        # Enveloppe progressive sur 3 périodes (évite les transitoires)
        env = min(1.0, t * f_source / 3.0)
        # Jz évalué à (q+1/2)·Δt (centrage temporel du schéma de Yee)
        Jz_t = Jz0 * np.sin(omega * (t + 0.5 * dt)) * env
        # Terme source : −(Δt/ε₀) · Jz  (éq. 16 du projet)
        Ez[src_i, 1:-1] -= (dt / eps0) * Jz_t * src_profile

        # ── Conditions limites (§2.3 du projet) ─────────────────────────────
        # Parois PEC : Ez = 0 sur y = 0 et y = b  (condition aux limites PEC)
        Ez[:, 0]  = 0.0
        Ez[:, -1] = 0.0
        # Bords du domaine : Ez = 0 (conditions nulles pour 2D, éq. projet §2.3)
        Ez[0, :]  = 0.0
        Ez[-1, :] = 0.0

        # ── Mise à jour de l'amplitude RMS ───────────────────────────────────
        Ez_amp = alpha_rms * Ez_amp + (1 - alpha_rms) * Ez**2

        # ── Enregistrement des instantanés ────────────────────────────────────
        if record_snapshots and (q % (Q // 4) == 0) and q > 0:
            snapshots.append((q, Ez.copy()))

    return Ez.copy(), np.sqrt(Ez_amp), snapshots


def fdtd_anim_frames(f_source, Q=2000, snap_start=1200, snap_every=6):
    """Comme fdtd_guide mais collecte des frames Ez pour animation."""
    Ez   = np.zeros((Nx, Ny))
    Bx_t = np.zeros((Nx, Ny))
    By_t = np.zeros((Nx, Ny))
    j_inner = np.arange(1, Ny - 1)
    src_profile = np.sin(np.pi * j_inner / (Ny - 1))
    omega = 2 * np.pi * f_source
    frames = []
    for q in range(Q):
        t = q * dt
        Bx_t[:, :-1] -= 0.5 * (Ez[:, 1:] - Ez[:, :-1])
        By_t[:-1, :] += 0.5 * (Ez[1:, :] - Ez[:-1, :])
        Ez[1:-1, 1:-1] += (
              0.5 * (By_t[1:-1, 1:-1] - By_t[:-2,  1:-1])
            - 0.5 * (Bx_t[1:-1, 1:-1] - Bx_t[1:-1, :-2])
        )
        env = min(1.0, t * f_source / 3.0)
        Jz_t = Jz0 * np.sin(omega * (t + 0.5 * dt)) * env
        Ez[src_i, 1:-1] -= (dt / eps0) * Jz_t * src_profile
        Ez[:, 0] = Ez[:, -1] = Ez[0, :] = Ez[-1, :] = 0.0
        if q >= snap_start and q % snap_every == 0:
            frames.append(Ez.copy())
    return frames


