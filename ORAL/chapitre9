# 1.  CONSTANTES PHYSIQUES
# ═══════════════════════════════════════════════════════════════════════════════
c    = 3e8               # vitesse de la lumière          [m/s]
eps0 = 8.854187817e-12   # permittivité du vide            [F/m]
mu0  = 4e-7 * np.pi      # perméabilité du vide            [H/m]


# ═══════════════════════════════════════════════════════════════════════════════
# 2.  PARAMÈTRES DE SIMULATION
# ═══════════════════════════════════════════════════════════════════════════════
f0     = 10e9        # fréquence de la source             [Hz]
lam0   = c / f0      # longueur d'onde λ₀                 [m]  = 3 cm

# Pas de discrétisation — éq. (13) : Δx = λ/20
dx = lam0 / 20       # = 1.5 mm
dy = dx              # grille carrée

# Pas temporel — éq. (14) : Δt = Δx / (2c)
dt = dx / (2 * c)    # = 2.5 ps

# Domaine
Nx          = 280    # cellules selon x  (axe du guide, direction de propagation)
N_inner     = 20     # cellules intérieures du guide (sans les deux parois PEC)
Ny          = N_inner + 2  # total avec parois : 22

# Largeur physique du guide
b = N_inner * dy     # b = 20 × 1.5 mm = 30 mm

# Fréquences de coupure — f_cn = n·c / (2b),  n = 1, 2, …
fc1 = c / (2 * b)    # 1re fréquence de coupure
fc2 = 2 * fc1        # 2e  fréquence de coupure

# Amplitude de la source (densité de courant)
Jz0 = 1.0 / (dt / eps0)   # → incrément Ez ~ 1 V/m par itération

# Position de la source (colonne)
src_i = 30

# Nombre d'itérations
Q_total = 3000

