)

# Colormap divergente pour Ez (bleu–blanc–rouge)
from matplotlib.colors import LinearSegmentedColormap
cmap_ez = LinearSegmentedColormap.from_list(
    'ez', ['#0a3dff', '#10102a', '#ff1a1a'])

# Colormap amplitude (feu)
cmap_amp = LinearSegmentedColormap.from_list(
    'amp', ['#08090f', '#4a0030', '#cc2800', '#ff8c00', '#ffff80'])

ax_title = fig.add_subplot(gs[0, :])
ax_title.axis('off')

titres_col = ["Guide BLOQUÉ  (f < f_c1)", "Guide PASSANT  (f_c1 < f < f_c2)"]
titres_row = ["E_z instantané", "Amplitude RMS de E_z"]

axes = [[fig.add_subplot(gs[row + 1, col])
         for col in range(2)]
        for row in range(2)]

for col, (nom, data) in enumerate(resultats.items()):
    f_sim = data["f"]
    ratio = f_sim / fc1

    for row, (champ, cmap, label_cb) in enumerate([
        (data["Ez"],  cmap_ez,  "E_z  [V/m]"),
