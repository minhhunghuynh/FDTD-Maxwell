        # Parois PEC (traits gris)
        for yp in [y_mm[0], y_mm[-1]]:
            ax.axhline(yp, color='#c0c8d0', linewidth=2.0)

        # Position de la source
        ax.axvline(x_mm[src_i], color='#ffff50', linewidth=0.8,
                   linestyle='--', alpha=0.6, label='source')

        # Colourbar
        cb = fig.colorbar(im, ax=ax, pad=0.02, fraction=0.04)
        cb.ax.tick_params(labelsize=7, colors='#8b9bb4')
        cb.set_label(label_cb, fontsize=7, color='#8b9bb4')

        # Décoration axes
        ax.set_xlabel("x  [mm]", fontsize=8, color='#8b9bb4')
        ax.set_ylabel("y  [mm]", fontsize=8, color='#8b9bb4')
        ax.tick_params(colors='#8b9bb4', labelsize=7)
        for spine in ax.spines.values():
            spine.set_edgecolor('#2a3040')

        # Titre de la sous-figure
        titre_mode = f"{titres_row[row]}\n"
        titre_mode += f"f = {f_sim/1e9:.3f} GHz,  f/f_c1 = {ratio:.2f}"
